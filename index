async function cargarProductos() {
  const cont = document.getElementById('grid-productos');
  cont.innerHTML = '<p class="cargando">Cargando productos...</p>';
  const snap = await getDocs(query(collection(db, 'productos'), orderBy('nombre', 'asc')));
  productosCache = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  renderProductos();
}
function renderProductos() {
  const cont = document.getElementById('grid-productos');
  const texto = document.getElementById('buscador').value.trim().toLowerCase();
  const categoria = document.getElementById('filtro-categoria').value;
  const filtrados = productosCache.filter(p => {
    const okTexto = !texto || p.nombre.toLowerCase().includes(texto);
    const okCat = !categoria || p.categoria === categoria;
    return okTexto && okCat;
  });
  if (filtrados.length === 0) {
    cont.innerHTML = '<p class="sin-resultados">No hay productos que coincidan.</p>';
    return;
  }
  cont.innerHTML = filtrados.map(p => `
    <div class="tarjeta">
      <img src="${p.imagenURL || ''}" alt="${p.nombre}">
      <div class="info">
        <span class="categoria-tag">${p.categoria}</span>
        <h3>${p.nombre}</h3>
        <div class="precio">${formatoMoneda(p.precio)}</div>
        ${p.stock <= 0 ? '<div style="color:#a13a2c;font-size:0.85em;">Agotado</div>' : ''}
        <div class="fila-cantidad">
          <input type="number" min="1" value="1" class="input-cantidad-producto" data-id="${p.id}" ${p.stock <= 0 ? 'disabled' : ''}>
          <button class="btn-primario" data-id="${p.id}" data-accion="agregar" ${p.stock <= 0 ? 'disabled' : ''} style="flex:1;">Agregar al carrito</button>
        </div>
      </div>
    </div>`).join('');
  cont.querySelectorAll('[data-accion="agregar"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const producto = productosCache.find(p => p.id === btn.dataset.id);
      const input = cont.querySelector(`.input-cantidad-producto[data-id="${btn.dataset.id}"]`);
      agregarAlCarrito(producto, input.value);
    });
  });
}
document.getElementById('buscador').addEventListener('input', renderProductos);
