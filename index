<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guadua con Aroma de Café</title>
<style>
  :root{
    --marron-oscuro:#3e2c20;
    --marron:#7a5230;
    --beige:#f3ead9;
    --verde:#4a6741;
    --acento:#c08a3e;
    --texto:#2b211a;
    --gris:#6b6055;
    --borde:#ddd0bd;
  }
  *{box-sizing:border-box;}
  body{margin:0;font-family:'Segoe UI',Arial,sans-serif;background:var(--beige);color:var(--texto);}
  header.topbar{
    background:var(--marron-oscuro);color:#fff;padding:14px 24px;
    display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;position:sticky;top:0;z-index:40;
  }
  header.topbar .marca{font-size:1.25em;font-weight:bold;}
  header.topbar .marca span{color:var(--acento);}
  nav.menu-principal{display:flex;gap:16px;flex-wrap:wrap;align-items:center;}
  nav.menu-principal a{color:#fff;text-decoration:none;font-size:0.95em;cursor:pointer;}
  nav.menu-principal a:hover{color:var(--acento);}
  button{cursor:pointer;border:none;border-radius:6px;padding:9px 16px;font-size:0.95em;}
  .btn-primario{background:var(--verde);color:#fff;}
  .btn-primario:hover{background:#3a5233;}
  .btn-secundario{background:#fff;color:var(--marron-oscuro);border:1px solid #fff;}
  .btn-peligro{background:#a13a2c;color:#fff;}
  .btn-link{background:none;color:var(--marron-oscuro);text-decoration:underline;padding:0;}
  .oculto{display:none !important;}

  .aviso{margin:14px 24px;padding:12px 16px;border-radius:8px;background:#fdeeea;color:#8a2c1d;border:1px solid #f3c4b6;font-size:0.92em;}

  section{padding:36px 24px;max-width:1200px;margin:0 auto;}
  section h2{font-size:1.6em;color:var(--marron-oscuro);border-bottom:3px solid var(--acento);display:inline-block;padding-bottom:4px;margin-bottom:20px;}

  .hero{background:linear-gradient(rgba(62,44,32,0.75),rgba(62,44,32,0.75)),url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="800" height="400"><rect width="800" height="400" fill="%237a5230"/></svg>');
    background-size:cover;color:#fff;text-align:center;padding:70px 24px;}
  .hero h1{font-size:2.2em;margin-bottom:10px;}
  .hero p{font-size:1.1em;max-width:700px;margin:0 auto 20px;}

  .grid-proyectos, .grid-productos, .grid-testimonios{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px;}

  .tarjeta{background:#fff;border:1px solid var(--borde);border-radius:10px;overflow:hidden;display:flex;flex-direction:column;}
  .tarjeta img{width:100%;height:180px;object-fit:cover;background:var(--beige);cursor:pointer;}
  .tarjeta .info{padding:14px;display:flex;flex-direction:column;gap:6px;flex:1;}
  .tarjeta h3{margin:0;font-size:1.1em;color:var(--marron-oscuro);}
  .categoria-tag{display:inline-block;background:var(--beige);color:var(--marron);font-size:0.75em;padding:3px 8px;border-radius:12px;align-self:flex-start;}
  .precio{font-weight:bold;color:var(--marron-oscuro);font-size:1.1em;}
  .fila-cantidad{display:flex;align-items:center;gap:8px;margin-top:6px;}
  .fila-cantidad input{width:55px;padding:6px;border:1px solid var(--borde);border-radius:6px;text-align:center;}
  .sin-resultados, .cargando{color:var(--gris);text-align:center;padding:40px;grid-column:1/-1;}

  .estrellas{color:var(--acento);font-size:1.1em;letter-spacing:1px;}
  .testimonio-texto{font-style:italic;color:var(--texto);}
  .testimonio-nombre{font-weight:bold;color:var(--marron-oscuro);margin-top:6px;}

  .panel-lateral{
    position:fixed;top:0;right:0;height:100%;width:340px;max-width:90vw;background:#fff;
    box-shadow:-4px 0 12px rgba(0,0,0,0.15);padding:20px;overflow-y:auto;z-index:50;
    display:flex;flex-direction:column;
  }
  .item-carrito{display:flex;gap:10px;border-bottom:1px solid var(--borde);padding:10px 0;align-items:center;}
  .item-carrito img{width:50px;height:50px;object-fit:cover;border-radius:6px;}
  .item-carrito .detalle{flex:1;font-size:0.9em;}
  .total-carrito{font-size:1.2em;font-weight:bold;margin:14px 0;text-align:right;}

  .modal{position:fixed;inset:0;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center;z-index:60;padding:16px;}
  .modal-contenido{background:#fff;border-radius:10px;padding:24px;max-width:560px;width:100%;max-height:90vh;overflow-y:auto;}
  .modal-contenido.ancho{max-width:760px;}
  .modal-contenido h2{margin-top:0;}
  .modal-contenido label{display:block;margin:10px 0 4px;font-size:0.9em;font-weight:bold;}
  .modal-contenido input, .modal-contenido select, .modal-contenido textarea{
    width:100%;padding:9px;border:1px solid var(--borde);border-radius:6px;font-size:0.95em;
  }
  .acciones-modal{display:flex;justify-content:flex-end;gap:10px;margin-top:16px;}
  .galeria-modal img, .galeria-modal video{width:100%;border-radius:8px;margin-bottom:10px;}

  .tabs{display:flex;gap:6px;margin:14px 0;border-bottom:2px solid var(--borde);flex-wrap:wrap;}
  .tab-btn{background:none;border:none;padding:10px 16px;font-weight:bold;color:var(--gris);border-bottom:3px solid transparent;}
  .tab-btn.activa{color:var(--marron-oscuro);border-color:var(--verde);}

  table{width:100%;border-collapse:collapse;background:#fff;}
  table th, table td{padding:10px;border-bottom:1px solid var(--borde);text-align:left;font-size:0.9em;}
  table img.miniatura{width:42px;height:42px;object-fit:cover;border-radius:5px;}

  #vista-admin{padding:20px 24px;max-width:1200px;margin:0 auto;}
  .cabecera-admin{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;margin-bottom:10px;}
  .badge-rol{background:var(--acento);color:#fff;font-size:0.75em;padding:2px 8px;border-radius:10px;margin-left:8px;}

  .form-card{background:#fff;border:1px solid var(--borde);border-radius:10px;padding:18px;margin-bottom:20px;max-width:560px;}
  .form-card label{display:block;margin:10px 0 4px;font-size:0.9em;font-weight:bold;}
  .form-card input, .form-card select, .form-card textarea{width:100%;padding:9px;border:1px solid var(--borde);border-radius:6px;}
  .ayuda{font-size:0.8em;color:var(--gris);margin-top:2px;}

  .mensaje{margin-top:10px;font-size:0.9em;}
  .mensaje.ok{color:var(--verde);}
  .mensaje.error{color:#a13a2c;}

  .estado-pedido{padding:3px 8px;border-radius:10px;font-size:0.8em;font-weight:bold;}
  .estado-pagado{background:#e8f0e6;color:var(--verde);}
  .estado-enviado{background:#e6eefb;color:#234a8a;}
  .estado-entregado{background:#eee;color:#444;}
  .estado-cancelado{background:#f4d6d2;color:#7a1f12;}

  footer{text-align:center;color:var(--gris);padding:24px;font-size:0.85em;background:#fff;border-top:1px solid var(--borde);}
</style>
</head>
<body>

<header class="topbar">
  <div class="marca">🎋 Guadua con <span>Aroma de Café</span></div>
  <nav class="menu-principal">
    <a data-ir="inicio">Inicio</a>
    <a data-ir="proyectos">Proyectos</a>
    <a data-ir="tienda">Tienda</a>
    <a data-ir="testimonios">Testimonios</a>
    <a data-ir="contacto">Contacto</a>
    <button class="btn-secundario" id="btn-abrir-carrito">🛒 (<span id="contador-carrito">0</span>)</button>
    <button class="btn-secundario" id="btn-acceso-empleados">Acceso colaboradores</button>
    <button class="btn-secundario oculto" id="btn-ir-admin">Panel de gestión</button>
  </nav>
</header>

<div id="aviso-config" class="aviso oculto">
  ⚠️ Falta configurar Firebase. Reemplaza los valores de ejemplo en "firebaseConfig" dentro del código,
  activa Authentication (correo/contraseña), Firestore y Storage. También reemplaza "TU_PAYPAL_CLIENT_ID" (PayPal),
  y los datos de WHATSAPP_NUMERO, NEQUI_NUMERO/NEQUI_TITULAR y BANCO_* (tus datos reales de cobro) en el código.
</div>

<!-- ===================== SITIO PÚBLICO ===================== -->
<div id="vista-publica">

  <div class="hero" id="inicio">
    <h1>Guadua con Aroma de Café</h1>
    <p>Arquitectura y diseño de interiores en guadua, y comercialización de guadua y productos derivados con identidad propia.</p>
    <button class="btn-primario" onclick="document.querySelector('[data-ir=proyectos]').click()">Ver nuestros proyectos</button>
  </div>

  <section id="proyectos">
    <h2>Nuestros proyectos</h2>
    <div id="grid-proyectos" class="grid-proyectos">
      <p class="cargando">Cargando proyectos...</p>
    </div>
  </section>

  <section id="tienda">
    <h2>Tienda</h2>
    <div class="filtros" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:18px;">
      <input id="buscador" placeholder="Buscar productos..." style="flex:1;min-width:220px;padding:10px;border:1px solid var(--borde);border-radius:6px;">
      <select id="filtro-categoria" style="padding:10px;border:1px solid var(--borde);border-radius:6px;">
        <option value="">Todas las categorías</option>
      </select>
    </div>
    <div id="grid-productos" class="grid-productos">
      <p class="cargando">Cargando productos...</p>
    </div>
  </section>

  <section id="testimonios">
    <h2>Lo que dicen nuestros clientes</h2>
    <div id="grid-testimonios" class="grid-testimonios">
      <p class="cargando">Cargando testimonios...</p>
    </div>
  </section>

  <section id="contacto">
    <h2>Contacto</h2>
    <p>Escríbenos para cotizar tu proyecto de arquitectura en guadua o tus productos a la medida.</p>
    <p>📞 Teléfono / WhatsApp: <strong>(reemplaza con tu número)</strong></p>
    <p>📧 Correo: <strong>(reemplaza con tu correo)</strong></p>
    <p>📍 Ubicación: <strong>(reemplaza con tu ciudad)</strong></p>
  </section>

</div>

<footer>© <span id="anio"></span> Guadua con Aroma de Café — Arquitectura, diseño y productos en guadua</footer>

<!-- ===================== MODAL PROYECTO ===================== -->
<div id="modal-proyecto" class="modal oculto">
  <div class="modal-contenido ancho">
    <button class="btn-link" id="btn-cerrar-proyecto" style="float:right;">Cerrar ✕</button>
    <h2 id="proyecto-titulo"></h2>
    <span class="categoria-tag" id="proyecto-categoria"></span>
    <p id="proyecto-descripcion" style="margin-top:10px;"></p>
    <div class="galeria-modal" id="proyecto-galeria"></div>
  </div>
</div>

<!-- ===================== CARRITO ===================== -->
<aside id="panel-carrito" class="panel-lateral oculto">
  <button class="btn-link" id="btn-cerrar-carrito" style="align-self:flex-end;">Cerrar ✕</button>
  <h2>Tu carrito</h2>
  <div id="items-carrito"><p class="sin-resultados">Tu carrito está vacío.</p></div>
  <div class="total-carrito">Total: <span id="total-carrito">$0</span></div>
  <button class="btn-primario" id="btn-ir-checkout">Continuar con el pedido</button>
</aside>

<!-- ===================== CHECKOUT ===================== -->
<div id="modal-checkout" class="modal oculto">
  <div class="modal-contenido">
    <h2>Datos de entrega</h2>
    <form id="form-checkout">
      <label>Nombre completo</label>
      <input type="text" id="chk-nombre" required>
      <label>Teléfono / WhatsApp</label>
      <input type="tel" id="chk-telefono" required>
      <label>Dirección</label>
      <input type="text" id="chk-direccion" required>
      <label>Ciudad</label>
      <input type="text" id="chk-ciudad" required>
      <label>Notas (opcional)</label>
      <textarea id="chk-notas" rows="2"></textarea>
      <div class="acciones-modal">
        <button type="button" class="btn-secundario" id="btn-cerrar-checkout">Cancelar</button>
        <button type="submit" class="btn-primario">Elegir método de pago</button>
      </div>
    </form>

    <div id="paso-metodo-pago" class="oculto">
      <h3>¿Cómo quieres pagar?</h3>
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px;">
        <button class="btn-secundario" id="btn-pago-paypal" style="text-align:left;">💳 Tarjeta (PayPal)</button>
        <button class="btn-secundario" id="btn-pago-nequi" style="text-align:left;">📱 Nequi</button>
        <button class="btn-secundario" id="btn-pago-banco" style="text-align:left;">🏦 Transferencia bancaria</button>
        <button class="btn-secundario" id="btn-pago-whatsapp" style="text-align:left;">💬 Coordinar por WhatsApp</button>
      </div>

      <div id="contenedor-paypal"></div>

      <div id="bloque-pago-manual" class="oculto">
        <div id="datos-pago-manual" style="background:var(--beige);padding:14px;border-radius:8px;font-size:0.9em;"></div>
        <label>Sube el comprobante de pago (captura o foto)</label>
        <input type="file" id="comprobante-pago" accept="image/*">
        <button class="btn-primario" id="btn-confirmar-pago-manual" style="margin-top:10px;width:100%;">Ya pagué, enviar pedido</button>
      </div>

      <button class="btn-link" id="btn-volver-datos-entrega" style="margin-top:10px;">← Volver a datos de entrega</button>
    </div>

    <p id="mensaje-checkout" class="mensaje"></p>
  </div>
</div>

<!-- ===================== CONFIRMACIÓN ===================== -->
<div id="modal-confirmacion" class="modal oculto">
  <div class="modal-contenido" style="text-align:center;">
    <h2>✅ ¡Pedido confirmado!</h2>
    <p>Gracias por tu compra. Te contactaremos pronto para coordinar la entrega.</p>
    <p id="ref-pedido" style="color:var(--gris);font-size:0.85em;"></p>
    <button class="btn-primario" id="btn-cerrar-confirmacion">Seguir explorando</button>
  </div>
</div>

<!-- ===================== ACCESO COLABORADORES ===================== -->
<div id="modal-login" class="modal oculto">
  <div class="modal-contenido">
    <div class="tabs">
      <button class="tab-btn activa" id="tab-login">Iniciar sesión</button>
      <button class="tab-btn" id="tab-registro">Crear cuenta</button>
    </div>

    <form id="form-login">
      <label>Correo</label>
      <input type="email" id="login-email" required>
      <label>Contraseña</label>
      <input type="password" id="login-password" required>
      <div class="acciones-modal">
        <button type="button" class="btn-secundario" id="btn-cerrar-login">Cancelar</button>
        <button type="submit" class="btn-primario">Entrar</button>
      </div>
      <p id="mensaje-login" class="mensaje"></p>
    </form>

    <form id="form-registro" class="oculto">
      <label>Nombre</label>
      <input type="text" id="registro-nombre" required>
      <label>Correo</label>
      <input type="email" id="registro-email" required>
      <label>Contraseña (mínimo 6 caracteres)</label>
      <input type="password" id="registro-password" required minlength="6">
      <div class="acciones-modal">
        <button type="button" class="btn-secundario" id="btn-cerrar-registro">Cancelar</button>
        <button type="submit" class="btn-primario">Crear cuenta</button>
      </div>
      <p id="mensaje-registro" class="mensaje"></p>
    </form>
  </div>
</div>

<!-- ===================== PANEL ADMIN / COLABORADOR ===================== -->
<div id="vista-admin" class="oculto">
  <div class="cabecera-admin">
    <div>
      Conectado como <strong id="texto-usuario-admin"></strong>
      <span class="badge-rol" id="badge-rol-admin"></span>
    </div>
    <div>
      <button class="btn-secundario" id="btn-volver-sitio">Ver sitio</button>
      <button class="btn-peligro" id="btn-cerrar-sesion">Cerrar sesión</button>
    </div>
  </div>

  <div class="tabs">
    <button class="tab-btn activa" id="tab-admin-proyectos">Proyectos</button>
    <button class="tab-btn" id="tab-admin-productos">Productos</button>
    <button class="tab-btn" id="tab-admin-testimonios">Testimonios</button>
    <button class="tab-btn" id="tab-admin-pedidos">Pedidos</button>
  </div>

  <!-- TAB PROYECTOS -->
  <div id="panel-admin-proyectos">
    <div class="form-card">
      <h3 id="titulo-form-proyecto">Agregar proyecto</h3>
      <form id="form-proyecto">
        <input type="hidden" id="proy-id">
        <label>Título del proyecto</label>
        <input type="text" id="proy-titulo" required>
        <label>Categoría</label>
        <select id="proy-categoria" required>
          <option value="Arquitectura">Arquitectura</option>
          <option value="Diseño de interiores">Diseño de interiores</option>
        </select>
        <label>Descripción</label>
        <textarea id="proy-descripcion" rows="3"></textarea>
        <label>Imágenes (puedes seleccionar varias)</label>
        <input type="file" id="proy-imagenes" accept="image/*" multiple>
        <label>O pega enlaces de imágenes (uno por línea, opcional)</label>
        <textarea id="proy-imagenes-enlaces" rows="2" placeholder="https://..."></textarea>
        <label>Videos (puedes seleccionar varios, archivos cortos recomendados)</label>
        <input type="file" id="proy-videos" accept="video/*" multiple>
        <label>O pega enlaces de videos (uno por línea, ej. YouTube, opcional)</label>
        <textarea id="proy-videos-enlaces" rows="2" placeholder="https://youtube.com/..."></textarea>
        <p class="ayuda" id="ayuda-media-actual"></p>
        <div class="acciones-modal">
          <button type="button" class="btn-secundario oculto" id="btn-cancelar-edicion-proyecto">Cancelar edición</button>
          <button type="submit" class="btn-primario">Guardar proyecto</button>
        </div>
        <p id="mensaje-proyecto" class="mensaje"></p>
      </form>
    </div>
    <h3>Proyectos publicados</h3>
    <div style="overflow-x:auto;">
      <table>
        <thead><tr><th>Imagen</th><th>Título</th><th>Categoría</th><th>Fotos</th><th>Videos</th><th>Acciones</th></tr></thead>
        <tbody id="tabla-proyectos-admin"><tr><td colspan="6">Cargando...</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- TAB PRODUCTOS -->
  <div id="panel-admin-productos" class="oculto">
    <div class="form-card">
      <h3 id="titulo-form-producto">Agregar producto</h3>
      <form id="form-producto">
        <input type="hidden" id="prod-id">
        <label>Nombre del producto</label>
        <input type="text" id="prod-nombre" required>
        <label>Categoría</label>
        <select id="prod-categoria" required></select>
        <label>Descripción</label>
        <textarea id="prod-descripcion" rows="2"></textarea>
        <label>Precio</label>
        <input type="number" id="prod-precio" min="0" step="100" required>
        <label>Stock disponible</label>
        <input type="number" id="prod-stock" min="0" value="0" required>
        <label>Imagen del producto</label>
        <input type="file" id="prod-imagen" accept="image/*">
        <label>O pega el enlace de la imagen (opcional)</label>
        <input type="text" id="prod-imagen-enlace" placeholder="https://...">
        <p class="ayuda" id="ayuda-imagen-actual"></p>
        <div class="acciones-modal">
          <button type="button" class="btn-secundario oculto" id="btn-cancelar-edicion-producto">Cancelar edición</button>
          <button type="submit" class="btn-primario">Guardar producto</button>
        </div>
        <p id="mensaje-producto" class="mensaje"></p>
      </form>
    </div>
    <h3>Productos publicados</h3>
    <div style="overflow-x:auto;">
      <table>
        <thead><tr><th>Imagen</th><th>Nombre</th><th>Categoría</th><th>Precio</th><th>Stock</th><th>Acciones</th></tr></thead>
        <tbody id="tabla-productos-admin"><tr><td colspan="6">Cargando...</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- TAB TESTIMONIOS -->
  <div id="panel-admin-testimonios" class="oculto">
    <div class="form-card">
      <h3 id="titulo-form-testimonio">Agregar testimonio</h3>
      <form id="form-testimonio">
        <input type="hidden" id="test-id">
        <label>Nombre del cliente</label>
        <input type="text" id="test-nombre" required>
        <label>Testimonio</label>
        <textarea id="test-texto" rows="3" required></textarea>
        <label>Calificación (1 a 5 estrellas)</label>
        <select id="test-calificacion">
          <option value="5">★★★★★ (5)</option>
          <option value="4">★★★★ (4)</option>
          <option value="3">★★★ (3)</option>
          <option value="2">★★ (2)</option>
          <option value="1">★ (1)</option>
        </select>
        <label>Foto del cliente (opcional)</label>
        <input type="file" id="test-foto" accept="image/*">
        <label>O pega el enlace de la foto (opcional)</label>
        <input type="text" id="test-foto-enlace" placeholder="https://...">
        <div class="acciones-modal">
          <button type="button" class="btn-secundario oculto" id="btn-cancelar-edicion-testimonio">Cancelar edición</button>
          <button type="submit" class="btn-primario">Guardar testimonio</button>
        </div>
        <p id="mensaje-testimonio" class="mensaje"></p>
      </form>
    </div>
    <h3>Testimonios publicados</h3>
    <div style="overflow-x:auto;">
      <table>
        <thead><tr><th>Cliente</th><th>Testimonio</th><th>Calificación</th><th>Acciones</th></tr></thead>
