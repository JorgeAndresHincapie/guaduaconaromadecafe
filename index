// =====================================================================
// CARRITO (guardado en este navegador con localStorage)
// =====================================================================
function leerCarrito() {
  try { return JSON.parse(localStorage.getItem('carritoGuadua') || '[]'); }
  catch (e) { return []; }
}
function guardarCarrito(carrito) {
  localStorage.setItem('carritoGuadua', JSON.stringify(carrito));
  actualizarContadorCarrito();
}
function actualizarContadorCarrito() {
  const carrito = leerCarrito();
  document.getElementById('contador-carrito').textContent = carrito.reduce((s, it) => s + it.cantidad, 0);
}
function agregarAlCarrito(producto, cantidad) {
  cantidad = Math.max(1, parseInt(cantidad) || 1);
  const carrito = leerCarrito();
  const existente = carrito.find(it => it.id === producto.id);
  if (existente) existente.cantidad += cantidad;
  else carrito.push({ id: producto.id, nombre: producto.nombre, imagenURL: producto.imagenURL, precio: producto.precio, cantidad });
  guardarCarrito(carrito);
  renderCarrito();
}
function quitarDelCarrito(id) {
  guardarCarrito(leerCarrito().filter(it => it.id !== id));
  renderCarrito();
}
function cambiarCantidadCarrito(id, nuevaCantidad) {
  nuevaCantidad = Math.max(1, parseInt(nuevaCantidad) || 1);
  const carrito = leerCarrito();
  const item = carrito.find(it => it.id === id);
  if (item) item.cantidad = nuevaCantidad;
  guardarCarrito(carrito);
  renderCarrito();
}
function totalCarrito() {
  return leerCarrito().reduce((s, it) => s + it.precio * it.cantidad, 0);
}
function renderCarrito() {
  const carrito = leerCarrito();
  const cont = document.getElementById('items-carrito');
  if (carrito.length === 0) {
    cont.innerHTML = '<p class="sin-resultados">Tu carrito está vacío.</p>';
  } else {
    cont.innerHTML = carrito.map(it => `
      <div class="item-carrito">
        <img src="${it.imagenURL || ''}" onerror="this.style.visibility='hidden'">
        <div class="detalle">
          <strong>${it.nombre}</strong><br>
          ${formatoMoneda(it.precio)} c/u<br>
          <input type="number" min="1" value="${it.cantidad}" style="width:55px;" data-id="${it.id}" class="input-cantidad-carrito">
        </div>
        <button class="btn-link" data-id="${it.id}" data-accion="quitar">✕</button>
      </div>`).join('');
  }
  document.getElementById('total-carrito').textContent = formatoMoneda(totalCarrito());
  actualizarContadorCarrito();
  cont.querySelectorAll('.input-cantidad-carrito').forEach(inp => inp.addEventListener('change', () => cambiarCantidadCarrito(inp.dataset.id, inp.value)));
  cont.querySelectorAll('[data-accion="quitar"]').forEach(btn => btn.addEventListener('click', () => quitarDelCarrito(btn.dataset.id)));
}
document.getElementById('btn-abrir-carrito').addEventListener('click', () => { renderCarrito(); mostrar('panel-carrito'); });
