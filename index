    return;
  }
  cont.innerHTML = proyectosCache.map(p => `
    <div class="tarjeta">
      <img src="${(p.imagenes && p.imagenes[0]) || ''}" data-id="${p.id}" class="abrir-proyecto">
      <div class="info">
        <span class="categoria-tag">${p.categoria}</span>
        <h3>${p.titulo}</h3>
        <p style="font-size:0.9em;color:var(--gris);">${(p.descripcion || '').slice(0, 90)}${(p.descripcion || '').length > 90 ? '...' : ''}</p>
        <button class="btn-secundario abrir-proyecto" data-id="${p.id}">Ver galería</button>
      </div>
    </div>`).join('');
  cont.querySelectorAll('.abrir-proyecto').forEach(el => {
    el.addEventListener('click', () => abrirModalProyecto(el.dataset.id));
  });
}
function abrirModalProyecto(id) {
  const p = proyectosCache.find(x => x.id === id);
  if (!p) return;
  document.getElementById('proyecto-titulo').textContent = p.titulo;
  document.getElementById('proyecto-categoria').textContent = p.categoria;
  document.getElementById('proyecto-descripcion').textContent = p.descripcion || '';
  const galeria = document.getElementById('proyecto-galeria');
  let html = '';
  (p.imagenes || []).forEach(url => html += `<img src="${url}">`);
  (p.videos || []).forEach(url => html += htmlVideo(url));
  galeria.innerHTML = html || '<p class="sin-resultados">Sin imágenes ni videos.</p>';
  mostrar('modal-proyecto');
}
