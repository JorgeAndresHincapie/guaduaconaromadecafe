function idYoutube(url) {
  const m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/))([\w-]{11})/);
  return m ? m[1] : null;
}
function htmlVideo(url) {
  const idYt = idYoutube(url);
  if (idYt) return `<iframe width="100%" height="280" src="https://www.youtube.com/embed/${idYt}" frameborder="0" allowfullscreen></iframe>`;
  return `<video src="${url}" controls></video>`;
}

