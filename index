async function cargarPedidosAdmin() {
  const tbody = document.getElementById('tabla-pedidos-admin');
  tbody.innerHTML = '<tr><td colspan="7">Cargando...</td></tr>';
  const snap = await getDocs(query(collection(db, 'pedidos'), orderBy('fecha', 'desc')));
  const pedidos = snap.docs.map(d => ({ id: d.id, ...d.data() }));
  if (pedidos.length === 0) {
    tbody.innerHTML = '<tr><td colspan="7">Aún no hay pedidos.</td></tr>';
    return;
  }
  tbody.innerHTML = pedidos.map(p => {
    const fecha = p.fecha?.toDate ? p.fecha.toDate().toLocaleString('es-CO') : '-';
    const itemsTexto = (p.items || []).map(it => `${it.cantidad}x ${it.nombre}`).join(', ');
    return `
      <tr>
        <td>${fecha}</td>
        <td>${p.cliente?.nombre || '-'}</td>
        <td>${p.cliente?.telefono || '-'}</td>
        <td>${formatoMoneda(p.total)}</td>
        <td>${p.metodoPago || '-'} ${p.comprobanteURL ? `<br><a href="${p.comprobanteURL}" target="_blank">ver comprobante</a>` : ''}</td>
        <td>
          <select data-id="${p.id}" class="select-estado-pedido">
            ${['pendiente_verificacion','pendiente_contacto','pagado','enviado','entregado','cancelado'].map(e =>
              `<option value="${e}" ${p.estado === e ? 'selected' : ''}>${e}</option>`).join('')}
          </select>
        </td>
        <td style="font-size:0.85em;">${itemsTexto}<br>${p.cliente?.direccion || ''}, ${p.cliente?.ciudad || ''}</td>
      </tr>`;
  }).join('');
  tbody.querySelectorAll('.select-estado-pedido').forEach(sel => {
    sel.addEventListener('change', async () => {
      await updateDoc(doc(db, 'pedidos', sel.dataset.id), { estado: sel.value });
    });
  });
}

