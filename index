      document.getElementById('proy-id').value = p.id;
      document.getElementById('proy-titulo').value = p.titulo;
      document.getElementById('proy-categoria').value = p.categoria;
      document.getElementById('proy-descripcion').value = p.descripcion || '';
      document.getElementById('titulo-form-proyecto').textContent = 'Editar proyecto: ' + p.titulo;
      document.getElementById('ayuda-media-actual').textContent = `Ya tiene ${(p.imagenes||[]).length} imagen(es) y ${(p.videos||[]).length} video(s). Los archivos nuevos que subas se agregarán a la galería existente.`;
      mostrar('btn-cancelar-edicion-proyecto');
      document.getElementById('form-proyecto').scrollIntoView({ behavior: 'smooth' });
