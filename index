async function subirArchivos(files, carpeta) {
  const urls = [];
  for (const file of files) {
    const refArchivo = ref(storage, `${carpeta}/${Date.now()}-${file.name}`);
    await uploadBytes(refArchivo, file);
    urls.push(await getDownloadURL(refArchivo));
  }
  return urls;
}

document.getElementById('form-proyecto').addEventListener('submit', async (e) => {
  e.preventDefault();
  const id = document.getElementById('proy-id').value;
  const titulo = document.getElementById('proy-titulo').value.trim();
  const categoria = document.getElementById('proy-categoria').value;
  const descripcion = document.getElementById('proy-descripcion').value.trim();
  const archivosImagenes = document.getElementById('proy-imagenes').files;
  const archivosVideos = document.getElementById('proy-videos').files;
  const enlacesImagenes = lineasAUrls(document.getElementById('proy-imagenes-enlaces').value);
  const enlacesVideos = lineasAUrls(document.getElementById('proy-videos-enlaces').value);

  setMensaje('mensaje-proyecto', 'Guardando proyecto (puede tardar si hay videos)...', '');
  try {
    const datosProyecto = { titulo, categoria, descripcion, actualizadoPor: usuarioActual.uid };
    const imagenesSubidas = archivosImagenes.length > 0 ? await subirArchivos(archivosImagenes, 'proyectos/imagenes') : [];
    const videosSubidos = archivosVideos.length > 0 ? await subirArchivos(archivosVideos, 'proyectos/videos') : [];
    const todasImagenes = [...imagenesSubidas, ...enlacesImagenes];
    const todosVideos = [...videosSubidos, ...enlacesVideos];
    if (todasImagenes.length > 0) datosProyecto.imagenes = todasImagenes;
    if (todosVideos.length > 0) datosProyecto.videos = todosVideos;

    if (id) {
      await updateDoc(doc(db, 'proyectos', id), datosProyecto);
    } else {
      datosProyecto.creadoPor = usuarioActual.uid;
      datosProyecto.fechaCreacion = serverTimestamp();
      await addDoc(collection(db, 'proyectos'), datosProyecto);
    }
    setMensaje('mensaje-proyecto', '¡Proyecto guardado!', 'ok');
    document.getElementById('form-proyecto').reset();
    document.getElementById('proy-id').value = '';
    document.getElementById('titulo-form-proyecto').textContent = 'Agregar proyecto';
    ocultar('btn-cancelar-edicion-proyecto');
    document.getElementById('ayuda-media-actual').textContent = '';
    cargarProyectosAdmin();
    cargarProyectosPublico();
  } catch (error) {
    setMensaje('mensaje-proyecto', 'Error: ' + error.message, 'error');
  }
});
