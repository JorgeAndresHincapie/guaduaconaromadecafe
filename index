async function guardarPedido(idPaypal, metodoPago, estado, comprobanteURL, abrirWhatsapp) {
  const carrito = leerCarrito();
  const total = totalCarrito();
  try {
    const refPedido = await addDoc(collection(db, 'pedidos'), {
      cliente: datosCliente, items: carrito, total, idPaypal: idPaypal || null,
      metodoPago, estado, comprobanteURL: comprobanteURL || null, fecha: serverTimestamp()
    });
    const referencia = refPedido.id.slice(0, 8).toUpperCase();

    if (abrirWhatsapp) {
      const resumen = carrito.map(it => `${it.cantidad}x ${it.nombre}`).join(', ');
      const mensaje = `Hola, quiero coordinar mi pedido (Ref: ${referencia}):\n${resumen}\nTotal: ${formatoMoneda(total)}\nNombre: ${datosCliente.nombre}\nDirección: ${datosCliente.direccion}, ${datosCliente.ciudad}`;
      window.open(`https://wa.me/${WHATSAPP_NUMERO}?text=${encodeURIComponent(mensaje)}`, '_blank');
    }

    localStorage.removeItem('carritoGuadua');
    document.getElementById('ref-pedido').textContent = 'Número de referencia: ' + referencia;
    ocultar('modal-checkout');
    ocultar('paso-metodo-pago');
    ocultar('bloque-pago-manual');
    document.getElementById('form-checkout').classList.remove('oculto');
    document.getElementById('form-checkout').reset();
    document.getElementById('contenedor-paypal').innerHTML = '';
    document.getElementById('comprobante-pago').value = '';
    actualizarContadorCarrito();
    renderCarrito();
    mostrar('modal-confirmacion');
  } catch (error) {
    setMensaje('mensaje-checkout', 'Hubo un error guardando el pedido. Contáctanos directamente.', 'error');
  }
}
